{
  "name": "claimwatch",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @claimwatch/web dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "pnpm -r typecheck && tsc -p e2e/tsconfig.json",
    "test": "vitest run",
    "e2e": "pnpm --filter @claimwatch/web build && playwright test",
    "build": "pnpm -r build",
    "test:db": "vitest run db.test.ts",
    "nightly": "tsx packages/pipeline/src/nightly/cli.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.2.0",
    "@playwright/test": "^1.53.0"
  }
}
